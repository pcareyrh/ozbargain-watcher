# Upstash Redis (required in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Protects /api/watch and config updates
CRON_SECRET=change-me

# Optional: separate secret for config UI (falls back to CRON_SECRET)
# ADMIN_SECRET=

# Alert triggers (Redis overrides win over these)
ALERT_VOTE_DELTA=15
ALERT_WINDOW_MINUTES=45
ALERT_COOLDOWN_HOURS=6

# Comma-separated category slugs; empty = all categories
# e.g. computing,gaming,electrical-electronics
CATEGORY_ALLOWLIST=

# Notifier: console | ntfy (legacy/operator fallback when no subscriptions)
NOTIFIER=console

# ntfy (used for subscriber fan-out always; also for operator fallback when NOTIFIER=ntfy)
# NTFY_SERVER=https://ntfy.sh
# NTFY_TOPIC=
# NTFY_TOKEN=
